# MUST CONFIGURE
# Where your media/data lives on the host.
DATA_ROOT="./runtime_data"

# Where service runtime config/databases live on the host.
# Delete this directory between test runs to reset app state without deleting media.
CONFIG_ROOT="./runtime"

# Private Internet Access credentials for the VPN-backed qBittorrent path.
PIA_LOCATION=ca_ontario
PIA_USER=
PIA_PASS=

ADMIN_USERNAME=admin
GLOBAL_PASSWORD=adminadmin

# Tailnet DNS suffix shown in the Tailscale admin console, for example tail1234.ts.net.
TAILNET_DOMAIN=

# CAN CONFIGURE
# Blank per-service usernames/passwords use these defaults.

COMPOSE_PROFILES=
TIMEZONE="America/New_York"
RECYCLARR_CRON_SCHEDULE="@daily"

PIA_LOCAL_NETWORK="192.168.0.0/16"
PIA_PORT_FORWARDING=0
DOWNLOAD_ROOT="${DATA_ROOT}/torrents"

TSDPROXY_DASHBOARD_PORT=8080
TSDPROXY_AUTHKEY_PATH=./secrets/tsdproxy_authkey
# Set true for test environments to expose tailnet HTTP and skip TLS certificate requests.
TSDPROXY_DISABLE_TLS=false
IMMICH_UPLOAD_LOCATION="${DATA_ROOT}/photos"

QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=
SONARR_USERNAME=
SONARR_PASSWORD=
RADARR_USERNAME=
RADARR_PASSWORD=
LIDARR_USERNAME=
LIDARR_PASSWORD=
PROWLARR_USERNAME=
PROWLARR_PASSWORD=
ADGUARD_USERNAME=
ADGUARD_PASSWORD=
CALIBRE_USERNAME=
CALIBRE_PASSWORD=
JELLYFIN_SERVER_NAME="Docker-Compose NAS"
JELLYFIN_ADMIN_USERNAME=
JELLYFIN_ADMIN_PASSWORD=
PAPERLESS_ADMIN_USER=
PAPERLESS_ADMIN_PASSWORD=
SEERR_JELLYFIN_ADMIN_USERNAME=
SEERR_JELLYFIN_ADMIN_PASSWORD=
SEERR_JELLYFIN_ADMIN_EMAIL=

HOMEPAGE_VAR_TITLE="Docker-Compose NAS"
HOMEPAGE_VAR_SEARCH_PROVIDER=google
HOMEPAGE_VAR_HEADER_STYLE=boxed
HOMEPAGE_VAR_WEATHER_CITY=
HOMEPAGE_VAR_WEATHER_LAT=
HOMEPAGE_VAR_WEATHER_LONG=
HOMEPAGE_VAR_WEATHER_UNIT=metric

SEERR_RADARR_PROFILE="HD-1080p"
SEERR_RADARR_MINIMUM_AVAILABILITY=released
SEERR_SONARR_PROFILE="HD-1080p"
SEERR_SONARR_LANGUAGE_PROFILE=
SEERR_SONARR_SEASON_FOLDERS=true
SEERR_SYNC_ENABLED=true
SEERR_AUTO_SEARCH=true
SEERR_JELLYFIN_EXTERNAL_URL=


# INTERNAL / GENERATED - USERS SHOULD NOT NEED TO CHANGE THESE
COMPOSE_PATH_SEPARATOR=:
COMPOSE_FILE=docker-compose.yml:adguardhome/docker-compose.yml:tandoor/docker-compose.yml:joplin/docker-compose.yml:homeassistant/docker-compose.yml:immich/docker-compose.yml:vaultwarden/docker-compose.yml:privoxy/docker-compose.yml:paperless/docker-compose.yml
USER_ID=1000
GROUP_ID=1000
SETUP_WAIT_TIMEOUT=300
TSDPROXY_ACCESS_MODE=443/https
TSDPROXY_URL_SCHEME=https

QBITTORRENT_SAVE_PATH="/data/torrents"
QBITTORRENT_TEMP_PATH="/data/torrents/incomplete"
SONARR_ROOT_FOLDER="/data/media/tv"
RADARR_ROOT_FOLDER="/data/media/movies"
LIDARR_ROOT_FOLDER="/data/media/music"
SONARR_DOWNLOAD_PATH="/data/torrents/tv"
RADARR_DOWNLOAD_PATH="/data/torrents/movies"
LIDARR_DOWNLOAD_PATH="/data/torrents/music"
SONARR_QBIT_CATEGORY=tv-sonarr
RADARR_QBIT_CATEGORY=radarr
LIDARR_QBIT_CATEGORY=lidarr

SONARR_API_KEY=
RADARR_API_KEY=
LIDARR_API_KEY=
PROWLARR_API_KEY=
BAZARR_API_KEY=
JELLYFIN_API_KEY=
SEERR_API_KEY=
SABNZBD_API_KEY=
IMMICH_API_KEY=
AUTOBRR_API_KEY=
HOMEASSISTANT_ACCESS_TOKEN=

IMMICH_DB_PASSWORD=postgres

QUI_REF=v1.19.0
SEERR_REF=v3.3.0
