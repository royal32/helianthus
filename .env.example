########################
#### MUST CONFIGURE ####
########################

# Where your media/data lives on the host.
DATA_ROOT="./runtime_data"

# Where service runtime config/databases live on the host.
# Delete this directory to reset app state without deleting media.
CONFIG_ROOT="./runtime"

# Private Internet Access credentials for the VPN-backed qBittorrent network binding.
PIA_LOCATION=ca_ontario
PIA_USER=
PIA_PASS=

# Credentials are applied to all services that use authentication, unless overridden below. 
ADMIN_USERNAME=admin
GLOBAL_PASSWORD=adminadmin

# Tailnet DNS suffix shown in the Tailscale admin console, for example tail1234.ts.net.
# HTTPS/TLS Certificates are automatically requested for this domain by TSDProxy.
# Services will be available through all Tailscale addresses, but only the ts.net url will have TLS certificates.
#    jellyfin/
#    jellyfin.<tailnet>.ts.net
#    100.x.y.z
TAILNET_DOMAIN=

########################
#### CAN CONFIGURE ####
########################

# Add optional services to COMPOSE_PROFILES separated by commas:
# - Cleanuparr is enabled by default to keep download queues tidy; remove it to disable;
# - qui is a custom qbittorrent interface;
# - Profilarr is only useful for private trackers;
# - Homepage is a customizable dashboard with quick links and weather.

COMPOSE_PROFILES=cleanuparr
LOCAL_NETWORK_HTTP_ACCESS=true
JELLYFIN_LOCAL_NETWORK_PORT=8096
SEERR_LOCAL_NETWORK_PORT=5055
TIMEZONE="America/New_York"

JELLYFIN_SERVER_NAME="Helianthus"

# Service version lock for the container that receives a custom patch.
QUI_REF=v1.20.0

PIA_LOCAL_NETWORK="192.168.0.0/16"
PIA_PORT_FORWARDING=1
DOWNLOAD_ROOT="${DATA_ROOT}/torrents"

LOCAL_NETWORK_BIND_ADDRESS=0.0.0.0

TSDPROXY_DASHBOARD_PORT=8080
# Set true for test environments to expose tailnet HTTP and skip TLS certificate requests.
TSDPROXY_DISABLE_TLS=true
# Restart TSDProxy after a clock gap indicates that the host resumed from sleep.
TSDPROXY_WAKE_CHECK_INTERVAL=30
TSDPROXY_WAKE_THRESHOLD_SECONDS=120
TSDPROXY_WAKE_GRACE_SECONDS=15
# Ofelia starts Profilarr shortly before 3am, then stops it after the run window to conserve memory usage.
PROFILARR_START_SCHEDULE="0 58 2 * * *"
PROFILARR_RUN_WINDOW=30m

# Service-specific credentials to override global defaults.
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=
SONARR_USERNAME=
SONARR_PASSWORD=
RADARR_USERNAME=
RADARR_PASSWORD=
PROWLARR_USERNAME=
PROWLARR_PASSWORD=
JELLYFIN_ADMIN_USERNAME=
JELLYFIN_ADMIN_PASSWORD=
SEERR_JELLYFIN_ADMIN_USERNAME=
SEERR_JELLYFIN_ADMIN_PASSWORD=
SEERR_JELLYFIN_ADMIN_EMAIL=

HOMEPAGE_VAR_TITLE="Docker-Compose NAS"
HOMEPAGE_VAR_SEARCH_PROVIDER=google
HOMEPAGE_VAR_HEADER_STYLE=boxed
HOMEPAGE_VAR_WEATHER_CITY=
HOMEPAGE_VAR_WEATHER_LAT=
HOMEPAGE_VAR_WEATHER_LONG=
HOMEPAGE_VAR_WEATHER_UNIT=metric

ARR_PUBLIC_QUALITY_PROFILE="Public 4K Preferred"
ARR_MAX_GB_PER_HOUR=8
RADARR_QUALITY_PROFILE="${ARR_PUBLIC_QUALITY_PROFILE}"
SONARR_QUALITY_PROFILE="${ARR_PUBLIC_QUALITY_PROFILE}"
RADARR_MAX_GB_PER_HOUR="${ARR_MAX_GB_PER_HOUR}"
SONARR_MAX_GB_PER_HOUR="${ARR_MAX_GB_PER_HOUR}"

AUDIO_DEFAULTS_DEBOUNCE_SECONDS=120
AUDIO_DEFAULTS_SCAN_INTERVAL_SECONDS=21600
AUDIO_DEFAULTS_STABILITY_CHECKS=2
AUDIO_DEFAULTS_STABILITY_INTERVAL_SECONDS=10

SEERR_RADARR_PROFILE="${RADARR_QUALITY_PROFILE}"
SEERR_RADARR_MINIMUM_AVAILABILITY=released
SEERR_SONARR_PROFILE="${SONARR_QUALITY_PROFILE}"
SEERR_SONARR_LANGUAGE_PROFILE=
SEERR_SONARR_SEASON_FOLDERS=true
SEERR_SYNC_ENABLED=true
SEERR_AUTO_SEARCH=true
SEERR_JELLYFIN_EXTERNAL_URL=

########################################################################
##### INTERNAL / GENERATED - USERS SHOULD NOT NEED TO CHANGE THESE #####
########################################################################
COMPOSE_PATH_SEPARATOR=:
COMPOSE_FILE=docker-compose.yml:local-network-access/docker-compose.yml:privoxy/docker-compose.yml
USER_ID=1000
GROUP_ID=1000
SETUP_WAIT_TIMEOUT=300
RECONCILE_INTERVAL_SECONDS=900
TSDPROXY_ACCESS_MODE=80/http
TSDPROXY_URL_SCHEME=http

QBITTORRENT_SAVE_PATH="/data/torrents"
QBITTORRENT_TEMP_PATH="/data/torrents/incomplete"
SONARR_ROOT_FOLDER="/data/media/tv"
RADARR_ROOT_FOLDER="/data/media/movies"
SONARR_DOWNLOAD_PATH="/data/torrents/tv"
RADARR_DOWNLOAD_PATH="/data/torrents/movies"
SONARR_QBIT_CATEGORY=tv-sonarr
RADARR_QBIT_CATEGORY=radarr
